<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Proficients Finance Tracker</title>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<style>

body{
font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto;
background:#f2f6ff;
margin:0;
color:#1d1d1f;
}

header{
padding:20px;
font-size:22px;
font-weight:600;
background:rgba(255,255,255,0.8);
backdrop-filter:blur(10px);
position:sticky;
top:0;
box-shadow:0 5px 15px rgba(0,0,0,0.05);
}

.container{
padding:20px;
max-width:1100px;
margin:auto;
}

.cards{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(180px,1fr));
gap:20px;
margin-bottom:30px;
}

.card{
background:white;
padding:20px;
border-radius:18px;
box-shadow:0 15px 35px rgba(0,0,0,0.07);
transition:0.3s;
}

.card:hover{
transform:translateY(-4px);
}

.card h3{
margin:0;
font-size:14px;
color:#777;
}

.card p{
font-size:26px;
margin-top:8px;
font-weight:600;
}

.section{
margin-top:35px;
}

table{
width:100%;
border-collapse:collapse;
background:white;
border-radius:15px;
overflow:hidden;
box-shadow:0 10px 30px rgba(0,0,0,0.05);
}

th,td{
padding:12px;
text-align:left;
border-bottom:1px solid #eee;
font-size:14px;
}

.chat{
background:white;
padding:15px;
border-radius:16px;
box-shadow:0 10px 25px rgba(0,0,0,0.05);
}

.message{
padding:10px 14px;
border-radius:12px;
margin-bottom:8px;
width:fit-content;
font-size:14px;
}

.income{background:#e7f1ff;color:#007aff}
.expense{background:#ffeaea;color:#ff3b30}
.pay{background:#fff6e6;color:#ff9500}

.fab{
position:fixed;
bottom:30px;
right:30px;
width:60px;
height:60px;
border-radius:50%;
background:#007aff;
color:white;
display:flex;
align-items:center;
justify-content:center;
font-size:30px;
cursor:pointer;
box-shadow:0 12px 30px rgba(0,0,0,0.2);
}

.modal{
position:fixed;
top:0;
left:0;
width:100%;
height:100%;
display:none;
align-items:center;
justify-content:center;
background:rgba(0,0,0,0.4);
backdrop-filter:blur(5px);
}

.modal-content{
background:white;
padding:25px;
border-radius:16px;
width:320px;
box-shadow:0 20px 40px rgba(0,0,0,0.2);
}

input,select{
width:100%;
padding:10px;
margin-top:10px;
border-radius:10px;
border:1px solid #ddd;
}

button{
background:#007aff;
color:white;
border:none;
padding:10px 16px;
border-radius:10px;
margin-top:12px;
cursor:pointer;
}

</style>
</head>

<body>

<header>
Proficients Finance Tracker
</header>

<div class="container">

<div class="cards">

<div class="card">
<h3>Total Income</h3>
<p id="income">$0</p>
</div>

<div class="card">
<h3>Total Expenses</h3>
<p id="expenses">$0</p>
</div>

<div class="card">
<h3>Employee Pay</h3>
<p id="pay">$0</p>
</div>

<div class="card">
<h3>Profit</h3>
<p id="profit">$0</p>
</div>

</div>

<div class="section">
<h2>Transactions</h2>

<table>
<thead>
<tr>
<th>Type</th>
<th>Client</th>
<th>Employee</th>
<th>Amount</th>
<th>Date</th>
</tr>
</thead>

<tbody id="table"></tbody>

</table>
</div>

<div class="section">
<h2>Monthly Finance Log</h2>
<div class="chat" id="chat"></div>
</div>

<div class="section">
<h2>Monthly Profit</h2>
<canvas id="chart"></canvas>
</div>

</div>

<div class="fab" onclick="openModal()">+</div>

<div class="modal" id="modal">

<div class="modal-content">

<h3>Add Transaction</h3>

<select id="type">
<option value="income">Income</option>
<option value="expense">Expense</option>
<option value="pay">Employee Pay</option>
</select>

<input id="client" placeholder="Client name">

<input id="employee" placeholder="Employee name (optional)">

<input id="amount" placeholder="Amount" type="number">

<input id="date" type="date">

<button onclick="add()">Save</button>

</div>
</div>

<script>

let data=JSON.parse(localStorage.getItem("proficientsFinance"))||[]

function save(){
localStorage.setItem("proficientsFinance",JSON.stringify(data))
}

function openModal(){
document.getElementById("modal").style.display="flex"
}

function closeModal(){
document.getElementById("modal").style.display="none"
}

function add(){

let t={
type:type.value,
client:client.value,
employee:employee.value,
amount:Number(amount.value),
date:date.value
}

data.push(t)

save()
render()
closeModal()

}

function render(){

let table=document.getElementById("table")
let chat=document.getElementById("chat")

table.innerHTML=""
chat.innerHTML=""

let income=0
let expenses=0
let pay=0

data.forEach(d=>{

let row=`
<tr>
<td>${d.type}</td>
<td>${d.client}</td>
<td>${d.employee||"-"}</td>
<td>$${d.amount}</td>
<td>${d.date}</td>
</tr>
`

table.innerHTML+=row

let msg=document.createElement("div")
msg.className="message "+d.type

if(d.type=="income"){
msg.innerText=`+ Received $${d.amount} from ${d.client}`
income+=d.amount
}

if(d.type=="expense"){
msg.innerText=`- Spent $${d.amount} on materials for ${d.client}`
expenses+=d.amount
}

if(d.type=="pay"){
msg.innerText=`- Paid ${d.employee} $${d.amount}`
pay+=d.amount
}

chat.appendChild(msg)

})

let profit=income-expenses-pay

incomeEl.innerText="$"+income
expensesEl.innerText="$"+expenses
payEl.innerText="$"+pay
profitEl.innerText="$"+profit

drawChart()

}

function drawChart(){

let months=new Array(12).fill(0)

data.forEach(d=>{

let m=new Date(d.date).getMonth()

if(d.type=="income") months[m]+=d.amount
if(d.type=="expense") months[m]-=d.amount
if(d.type=="pay") months[m]-=d.amount

})

new Chart(chart,{
type:"line",
data:{
labels:["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"],
datasets:[{
label:"Monthly Profit",
data:months,
tension:0.4
}]
}
})

}

render()

</script>

</body>
</html>
